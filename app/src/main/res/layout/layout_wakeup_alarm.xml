<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510"
    android:fitsSystemWindows="true">

    <!-- Background Image / View -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.3"
        android:src="@drawable/dialog_gradient_background" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/baseline_wb_sunny_24"
            app:tint="#FFC107"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOOD MORNING"
            android:textColor="#80FFFFFF"
            android:textSize="16sp"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:00 AM"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time to Wake Up!"
            android:textColor="#00FFC2"
            android:textSize="20sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Bottom Actions Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="48dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanQR"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Scan QR to Stop Alarm"
            android:textSize="18sp"
            app:cornerRadius="32dp"
            app:icon="@drawable/baseline_qr_code_scanner_24"
            app:iconGravity="textStart"
            android:backgroundTint="#6C63FF"
            android:textColor="#FFFFFF" />

        <!-- Helper Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Scan 'reality://smart_sleep' QR code to dismiss"
            android:textColor="#60FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</FrameLayout>
