<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Why Google Connection?"
        app:titleTextColor="?attr/colorOnSurface"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:navigationIconTint="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Why do we need Google permissions?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Privacy First Architecture"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:fontFamily="sans-serif-light"
                android:text="We DO NOT store any of your data on our server. Not your email, not your tokens, nothing. Everything stays inside the Reality app on your device, completely local and encrypted.\n\nWe use a completely Serverless architecture (Cloudflare Workers) to securely generate an irreversible User ID and Password using a one-way mathematical hash of your email. \n\nNo one can reverse your User ID to get your email. From then on, any AI features, Elite Membership, or verification only uses that anonymous User ID."
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Why such high permissions?"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:fontFamily="sans-serif-light"
                android:text="Reality is deeply integrated with Google Drive, Google Tasks, and Google Calendar. By integrating directly with Google instead of building our own custom storage servers, you unlock massive benefits:\n\n• Google Workspace AI: Summarize complex reports natively since your reports live in Google Drive.\n• You can use Gemini in Google Docs directly alongside our Reality plan generation features.\n• Huge, free 15GB Storage that keeps the Reality app size incredibly small on your phone (around 150MB) even after years of continuous use!\n• Seamless Cross-Device Syncing of all your plans, reports, tasks, and calendars, entirely without trusting our servers with your personal data."
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Extremely Low Cost"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:fontFamily="sans-serif-light"
                android:text="Because we don't have to pay massive cloud storage and server bills to hold millions of users' data, our subscription cost is incredibly low—starting at less than $0.10 USD per month! You get the ultimate private productivity OS directly on your phone."
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
