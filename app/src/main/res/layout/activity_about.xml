<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <include
        android:id="@+id/include_header"
        layout="@layout/include_standard_header"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Pattern Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_pattern_zen"
        android:alpha="0.4"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/include_header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/app_logo"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                android:elevation="8dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reality"
                android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"
                android:textSize="32sp"
                android:textStyle="bold"

                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Version 1.0.6"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- Update Check Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:strokeWidth="1dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_system_update_24"
                        app:tint="?attr/colorPrimary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Check for Updates"
                            android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tv_update_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep Reality at its best"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progress_update"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorSize="20dp"
                        app:trackThickness="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Update Check Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBetaUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:strokeWidth="1dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_system_update_24"
                        app:tint="?attr/colorPrimary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Check for Beta Updates"
                            android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tv_beta_update_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get early access features"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progress_beta_update"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorSize="20dp"
                        app:trackThickness="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Update Check Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRaiseIssue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:strokeWidth="1dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_bug_report_24"
                        app:tint="?attr/colorPrimary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Report an Issue"
                            android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tv_raise_issue_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help us improve Reality"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progress_raise_issue"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorSize="20dp"
                        app:trackThickness="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Markdown Content -->
            <TextView
                android:id="@+id/tv_markdown_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"
                android:padding="8dp"/>






            <!-- Support Us Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSupportUs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="2dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💚"
                        android:textSize="32sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Support Reality"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textStyle="bold"
                        android:textSize="20sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Help keep this app ad-free &amp; source-available"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="13sp"
                        android:alpha="0.8"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSupportUs"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤️ Support via UPI"
                        android:textSize="14sp"
                        app:cornerRadius="20dp"
                        android:layout_marginTop="16dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Profile / Developer Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Meet the Creator"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Placeholder for Avatar if available, using initial for now -->
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/rounded_button_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="P"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"
                                android:layout_gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pawan Washudev"
                                android:textColor="?attr/colorPrimary"

                                android:textSize="20sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Project Lead &amp; Developer"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginVertical="16dp"/>

                    <!-- Social Links Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">


                        <!-- GitHub -->
                        <LinearLayout
                            android:id="@+id/btn_github"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_code_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GitHub"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                        <!-- Website -->
                        <LinearLayout
                            android:id="@+id/btn_website"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_language_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Website"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                        <!-- Contact Developer -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Contact Developer Directly:"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:layout_marginTop="24dp"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Having difficulties or need help? Reach out directly via Email, Telegram, or WhatsApp."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                            android:layout_marginBottom="16dp"/>

                        <!-- Email -->
                        <LinearLayout
                            android:id="@+id/btn_contact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_email_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email Support"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                        <!-- WhatsApp -->
                        <LinearLayout
                            android:id="@+id/btn_whatsapp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_chat_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WhatsApp Support"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                        <!-- Dev Telegram -->
                        <LinearLayout
                            android:id="@+id/btn_telegram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_send_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Developer Telegram"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                        <!-- Instagram -->
                        <LinearLayout
                            android:id="@+id/btn_instagram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_language_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Instagram Support"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                        <!-- LinkedIn -->
                        <LinearLayout
                            android:id="@+id/btn_linkedin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackground"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_language_24"
                                app:tint="?attr/colorOnSurface"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LinkedIn Support"
                                android:textSize="16sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Legal / Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Made with ❤️ for Focus"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:alpha="0.7"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"
                android:textSize="15sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- App Logo & Version -->
            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/app_logo"
                android:layout_marginTop="32dp"/>

            <!-- Source-Available Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Source-Available"
                android:textColor="?attr/colorPrimary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/btn_source_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Source Code on GitHub"
                android:textColor="?attr/colorSecondary"
                android:textSize="14sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Privacy Policy -->
            <TextView
                android:id="@+id/btn_privacy_policy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy Policy"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2026 Neubofy. All rights reserved."
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Made with ❤️ in India"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
