<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    >

    <!-- Gradient Glow at Top -->
    <View
        android:id="@+id/gradient_glow"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/dialog_gradient_background"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Header -->
    <include
        android:id="@+id/include_header"
        layout="@layout/include_standard_header"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/include_header"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section: Nightly Protocol Schedule -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nightly Protocol Sync Window"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/btn_edit_schedule"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/baseline_edit_24"
                    app:tint="?attr/colorPrimary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Edit"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Saved Schedule Display -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_saved_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_saved_schedule"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"
        android:fontFamily="monospace"/>

                        <ImageView
                            android:id="@+id/btn_delete_schedule"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:padding="6dp"
                            android:src="@drawable/baseline_delete_24"
                            app:tint="?attr/colorError"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Delete"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                    
                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"/>

                    <!-- Auto-Start UI Removed - Process is now fully manual -->

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Schedule Edit Form (hidden when saved) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_schedule_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Set the time window for Nightly Agent synchronization"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="12dp"/>

                    <!-- Time Window Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="From"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_start_time"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="22:00"
                                android:textAllCaps="false"
                                app:cornerRadius="8dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="to"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginHorizontal="16dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="To"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_end_time"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="23:59"
                                android:textAllCaps="false"
                                app:cornerRadius="8dp"/>
                        </LinearLayout>
                    </LinearLayout>


                    <!-- Save Schedule Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_schedule"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Save Schedule"
                        android:textAllCaps="false"
                        app:cornerRadius="8dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- Section: AI Prompts & Logic -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI &amp; Prompts"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_manage_prompts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:text="Manage System Prompts"
                    app:icon="@drawable/baseline_edit_24"
                    app:iconGravity="textStart"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_manage_templates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:text="Manage Docs Templates"
                    app:icon="@drawable/baseline_edit_24"
                    app:iconGravity="textStart"/>
                    
                 <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Customize your Diary, Plans, and Reports."
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                 android:layout_marginBottom="24dp"/>

            <!-- Section: Data Retention Policies -->
            <!-- Clear Nightly Memory -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Data Management"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Clear Memory Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_nightly_memory"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clear Nightly Memory"
                android:textColor="?attr/colorError"
                app:strokeColor="?attr/colorError"
                app:icon="@drawable/baseline_delete_24"
                app:iconTint="?attr/colorError"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clears stored Nightly Protocol session data from the database. Does not delete Drive files."
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="24dp"/>


            <!-- Section: Custom Step Enablement & Sub-Permissions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step Toggles &amp; Permissions"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Toggles container -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Step 1: Fetch Analytics Toggle -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_step_analytics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Step 1: Fetch Analytics"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>

                    <!-- Sub-permission layout for Step 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_tasks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fetch Tasks"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_calendar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fetch Calendar Events"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_tapasya"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fetch Tapasya Sessions"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_distraction"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fetch Distraction App Usage"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_health"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fetch Health &amp; Sleep Data"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>
                    </LinearLayout>

                    <!-- Step 2: Create Diary Toggle -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_step_diary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Step 2: Create Diary"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>

                    <!-- Sub-permission layout for Step 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_ai_questions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Include AI Reflection Questions"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>
                    </LinearLayout>

                    <!-- Step 3: Save Today Analytics Toggle -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_step_save_analytics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Step 3: Save Today Analytics"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>

                    <!-- Sub-permission layout for Step 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_save_sheet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Backup to Reality Sheet"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>
                    </LinearLayout>

                    <!-- Step 4: Create Plan Toggle -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_step_create_plan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Step 4: Create Plan"
                        android:checked="true"
                        android:layout_marginBottom="16dp"/>

                    <!-- Step 5: Apply Plan Toggle -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_step_apply_plan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Step 5: Apply Plan"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>

                    <!-- Sub-permission layout for Step 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_apply_alarm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Schedule Wakeup Alarm"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_apply_tasks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Create Google Tasks"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_apply_calendar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Create Calendar Events"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_apply_sleep"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Update Sleep Schedule"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_perm_apply_distraction"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Update Distraction App Limit"
                            android:checked="true"
                            android:layout_marginBottom="4dp"/>
                    </LinearLayout>

                    <!-- Step 6: Generate Report Toggle -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_step_report"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Step 6: Report &amp; Finalize"
                        android:checked="true"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Additional Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Advanced"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>



        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
